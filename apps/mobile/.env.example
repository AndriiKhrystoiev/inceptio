# Mobile build configuration (Expo inlines EXPO_PUBLIC_* at build time).
# Copy to `apps/mobile/.env` (gitignored).

# ── Dev/test API access (honored ONLY when __DEV__ === true) ────────────────
# Production ALWAYS uses the keyless public endpoint and never sends a key
# (see src/config/api.ts). Do NOT set these two in an EAS production profile.

# Optional: point dev at the keyed upstream so testing uses your account's
# limits instead of the anonymous per-IP limit on api-public.
EXPO_PUBLIC_ASTROLOGY_BASE_URL=https://api.astrology-api.io/api/v3

# Your DEV API key (the "From anywhere" dev key, e.g. inceptio-dev-postman).
# Never put the production "backend only" key here.
EXPO_PUBLIC_ASTROLOGY_DEV_KEY=

# ── Update gate (version check) ─────────────────────────────────────────────
# Public URL of a hosted version-policy JSON (see version-policy.example.json
# for the shape). Drives the in-app force/soft update prompts. Edit the hosted
# file to change which versions are gated — no app release needed.
# REQUIRED IN PRODUCTION for the update gate to work (bake it into the EAS prod
# profile too). Unset → gate is inert (never force-upgrades). In __DEV__ the real
# fetch is skipped regardless; use the in-app dev simulator to preview the UI.
EXPO_PUBLIC_VERSION_POLICY_URL=
