# Mobile dev/test build configuration (Expo inlines EXPO_PUBLIC_* at build time).
#
# Copy to `apps/mobile/.env` (gitignored) for local dev. These values are
# honored ONLY in dev builds (__DEV__ === true). Production builds ALWAYS use
# the keyless public endpoint and never send a key — see src/config/api.ts.
#
# Do NOT set these in an EAS production build profile.

# Optional: point dev at the keyed upstream so testing uses your account's
# limits instead of the anonymous per-IP limit on api-public.
EXPO_PUBLIC_ASTROLOGY_BASE_URL=https://api.astrology-api.io/api/v3

# Your DEV API key (the "From anywhere" dev key, e.g. inceptio-dev-postman).
# Never put the production "backend only" key here.
EXPO_PUBLIC_ASTROLOGY_DEV_KEY=
