{
  "expo": {
    "name": "Inceptio",
    "slug": "inceptio",
    "scheme": "inceptio",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon-ios.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.inceptio.app"
    },
    "android": {
      "package": "io.inceptio.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F0A1F",
        "foregroundImage": "./assets/icon-android-foreground.png"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "Inceptio adds your chosen moments to your phone's calendar."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Inceptio uses your location to find astrologically favorable moments for events near you."
        }
      ],
      "expo-sharing",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0A1F",
          "dark": { "image": "./assets/splash-icon.png", "backgroundColor": "#0F0A1F" }
        }
      ]
    ]
  }
}
